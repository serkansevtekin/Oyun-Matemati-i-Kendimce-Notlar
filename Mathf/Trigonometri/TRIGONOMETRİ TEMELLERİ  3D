    // ============================================================
    #region 3 DAİRESEL HAREKET (CIRCULAR MOTION)
    // ============================================================
    /*
        En kalsik kullanım
        
           z = cos(angle) * radius;
            x = sin(angle) * radius;
            
    */

    [Header("Dairesel Hareket")]
    public float radius = 5f;
    public float speed = 1f;
    public Transform centerPoint; // Döneceği merkez obje (Boş bir GameObject olabilir)
    void CircularMovement()
    {
        float angle = Time.time * speed;

        float z = Mathf.Cos(angle) * radius;
        float x = Mathf.Sin(angle) * radius;


        transform.position = centerPoint.position + new Vector3(x, 0, z);
    }
    #endregion



    // ============================================================
    #region 4 AÇIDAN YÖN VEKTÖRÜ ÜRETME 
    // ============================================================
    /*
        Bir açıyı (degree/radyan) oyun içindeki bir yöne (Vector3) çevirme

        Kullanım Alanları:
                - Mermi ateşleme yönü
                - Düşmanların bakış açısı
                - 360 derecelik dairesel dizilimler

        Matematik
        - X = Mathf.Sin(angle)
        - Z = Mathf.Cos(angle)


        Not: Birim çember üzerinde çalıştığımız için oluşan 'dir' vektörü zaten  uzunluğu 1 olan bir "Birim Vektör" dür (Normalized). Fazladan .normalized çağrımana gerek yoktur, ancak bir yarıçap (radius) ile çarparsan, yönü korumak için tekrar normalize etmen gerekebilir
    */

    Vector3 DirectionFromAngle(float angleDegrees)
    {
        // Önce dereceyi radyana çevriyoruz
        float angle = angleDegrees * Mathf.Deg2Rad;

        // Yönü hesaplyoruz (Bu vektör zaten normalize haldedir)
        Vector3 dir = new Vector3(Mathf.Sin(angle), 0, Mathf.Cos(angle));

        Debug.Log("Üretilen Yön: " + dir);

        return dir;
        // Örnek: Eğer bunu 5 birimlik bir hıza çevirmek istersen:
        // Vector3 velocity = dir * 5f;
    }

    #endregion


    // ============================================================
    #region 5 ATAN2 (EN ÖNEMLİ TRIG FONKSİYONU)
    // ============================================================

    /*
        Bir vektörün açısnı bulur

        Atan2(y, x)

        Unity 3D'de genelde:
                            Atan2(x, z); kullanılır
        
    */

    public Transform _Target;
    private void LookAtTarget()
    {
        if (_Target == null) return;

        // Fark vektörü
        Vector3 diffVector = _Target.position - transform.position;

        if (diffVector.sqrMagnitude < 0.001f) return;

        // 1. Önce sadece yönü al (Uzaklığı temizle)
        Vector3 directionVektor = diffVector.normalized;

        // 2. Artık elinde sadece saf bir yön vektörü var
        float angle = Mathf.Atan2(directionVektor.x, directionVektor.z) * Mathf.Rad2Deg;

        transform.rotation = Quaternion.Euler(0, angle, 0);

    }

    #endregion



    // ============================================================
    #region 6 VECTORLER ARASI AÇI
    // ============================================================
    /*
     PERFORMANS NOTU:

         Açı hesaplamak (Acos) yerine Dot Product kullanıyoruz.

         Dot sonucu:
                      1 -> Tam önde
                      0 -> Dik (90 derece açıda)
                     -1 -> Tam arkada
    */
    private float viewAngle = 45f;
    private float cosViewAngle;
    /*   void Start()
      {
          // Trigonometrik hesaplamayı sadece 1 kez, oyun başında yapıyoruz
          cosViewAngle = Mathf.Cos(viewAngle * Mathf.Deg2Rad);
      } */
    private bool IsTargetInView()
    {


        Vector3 diff = _Target.position - transform.position;

        // Kare alma işlemi, karekök almaktan (magnitude) her zaman daha hızlıdır
        if (diff.sqrMagnitude < 0.001f) return false;
        Vector3 directionToTarget = diff.normalized;

        float dotProduct = Vector3.Dot(transform.forward, directionToTarget);

        return dotProduct > cosViewAngle;
    }

    #endregion



    // ============================================================
    #region 7 EĞİM (SLOPE) HESAPLAMA
