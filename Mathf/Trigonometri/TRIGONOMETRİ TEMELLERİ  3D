                    public Transform target;

                    [Header("FOV Ayarı)]
                    public float totalViewAngle = 60f;
                    private float cosThreshold;

                    void Start()
                    {
                        // Eşik değerini birkez hesapa: Cos(30 derece ) gibi
                        cosThreshold = Mathf.Cos(totalViewAngle * 0.5f * Mathf.Deg2Rad);
                    }

                    void Update()
                    {
                        if(target == null) return;

                        Vector3 differentVector = target.position - transform.position;
                        
                        if(differentVector.sqrMagnitude < 0.001f) return;

                        Vector3 directionToTarget = differentVector.normalized;
                        
