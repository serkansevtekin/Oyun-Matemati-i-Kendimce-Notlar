    /*
        Trigonometrik fonksiyonları yönlendirme mantığı:

            1. 2D Düzlem (Ekran Kordinatları - UI/2D Oyunlar):
                    
                    - Sin(angle) -> Y eksenini (Dikey) kontrol eder
                    - Cos(angle) -> X eksenini (Yatay) kontrol eder
                    - Not: Gelende 0 derece X eksenindedir
            
            
            2. 3D Uzat (Yer Düzlemi - Y ekseni yukarıda):

                    - 3D oyunlarda karakterlerin yerde hareket ettiği düzlem XZ düzlemidir
                    - Sin(angle) -> X eksninin (Sağ/Sol) etkiler
                    - Cos(angle) -> Z eksenini (İleri/Geri) etkiler
                    - Not: Unity'de "Forward" vektörü Z'dir, bu yüzden Cos genellikle Z ile eşleşir.

            
           
        
        Trigonometrik fonksiyonlarda Radyan kullanılır
    */

    void SinCosTemel()
    {
        float angle = 45f * Mathf.Deg2Rad;

        float sinValue = Mathf.Sin(angle);
        float cosValue = Mathf.Cos(angle);
        Debug.Log("Sin: " + sinValue);
        Debug.Log("Cos: " + cosValue);

    }

