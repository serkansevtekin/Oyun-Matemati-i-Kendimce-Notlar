    /*
        Tan fonksiyonu eğim hesaplamak için kullanılır

        tan(angle) = karşu / komşu

    */

    void CalculateSlope()
    {
        float height = 5f;
        float distance = 10f;

        float slopeAngle = Mathf.Atan(height / distance) * Mathf.Rad2Deg;

        Debug.Log("Eğim Açısı: " + slopeAngle);
    }



