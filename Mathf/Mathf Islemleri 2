    #region Logaritmik ve Üstel Fonksiyonlar

    #region Exp(f) -> [hızlanan] [Patlayıcı Artış]

    /*
    [Patlayıcı Artış]
        En "acımasız" büyüme. Eğer Clamp kullanmazsan, birkaç seviye sonra oyunundaki tüm sayılar Infinity olur ve her şey birbirine girer.

            Bu, Pow fonksiyonunun özel bir halidir. Pow bazen çok kontrolsüz gelebilir ama Exp daha matematiksel ve organik bir hızlanma sağlar
                
                    Kullanım:
                            -> Çok hızlı büyümesi gereken, oyunun sonunda bir anda devasa hale helen olaylar (bir şehrin nüfusu, bir virüsün yayılması vb.)

                    Mathf.Exp kullanırken genellikle x değerini küçültmek veya bir katsayı ile çarpmak gerekir. İşte güvenli kullanım örneği:

                        Örnek:  
                            // 'playerLevel * 0.1f' yaparak artış hızını "yumuşatıyoruz"
                            // 0.1 gibi küçük bir çarpan, Exp'in kontolsüz patlamasını engeller.
                            float rawValue = Mathf.Exp(playerLevel * 0.1f);

                            // Yine de bir tavan değer (Limit koyuyoruz)
                            float rawValueLimited = Mathf.Clamp(rawValue, 1f, 1000f);

    */
    /*  Mathf.Exp(f): e sayısının (2.718...) belitilen kuvetini alır.
                 Yumuşak geçişli animasyonlarda çok işine yarar 
                 
        Neden Kullanılır?
            Doğal Büyüme: Doğadaki birçok büyüme süreci (nüfus artışı, bakteri çoğalması, bileşik faiz) üstel fonksiyonlarla ifade edilir.
            
            Zaman Ayarı: Mathf.Exp(t) kullandığınızda geçişler başlangıçta yavaş, sonrasında hızlanan (exponential) bir ivme kazanır.
            
            Sönümlenme (Damping): Eğer Mathf.Exp(-time) şeklinde negatif bir değer verirseniz, değerin hızla sıfıra yaklaşan bir sönümlenme efekti verdiğini görürsünüz. Bu, fiziksel nesnelerin durma anındaki yumuşaklığı için birebirdir.

            Işık Efektleri: Bir lambanın yanarken parlaklığını Mathf.Exp ile artırırsan "daha gerçekçi" bir yanma efekti alırsın.

            Kamera Sallanması: Eğer bir patlamadan sonra kameranın sönümlenmesini istiyorsan, Mathf.Exp(-Time.time) gibi negatif bir değer kullanarak sarsıntının "sönerek" durmasını sağlayabilirsin.  

                 */

    // Örnek : Yumuşak İvmelenme (Smooth Acceleration)
    //      -> Bir nesnenin zamanla hızının veya büyüklüğünün "doğal" bir şekilde artmasını istiyram Mathf.Exp harika bir tercih
    [Space]
    [Header("Exp Değerleri")]
    public float maksimumBoyut = 10f;
    public float hiz = 0.5f;
    void ExpKullanim()
    {
        if (transform.localScale.x < maksimumBoyut)
        {
            // Zaman ilerledikçe nesneyi daha hızlı büyütür
            // Time.time 0'dan başlar, e'0 = 1'dir
            float boyut = Mathf.Exp(Time.time * hiz);


            // Mathf.Min ile hedefBoyut ile maksimumBoyut arasındaki küçüküğü seç
            // Eğer hedefBoyut 10'u geçerse, sonuç her zaman 10 kalacak.
            float finalBoyut = Mathf.Min(boyut, maksimumBoyut);
            transform.localScale = new Vector3(finalBoyut, finalBoyut, finalBoyut);


        }
        else
        {
            // Büyüme durdu, burada başka bir şey yapabilirsin
            Debug.Log("Mksimum boyuta ulaşıldı");
        }

    }

