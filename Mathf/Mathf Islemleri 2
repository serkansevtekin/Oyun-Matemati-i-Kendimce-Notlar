    [Space]
    [Header("PerlinNoise Değerleri")]
    public float perlinSpeed = 1f;
    public float perlinIntensity = 2f;
    public Camera m_Camera;

    // Kamera Sarsıntısı (Doğal His)
    private void CameraShake()
    {
        // Time.time değerini kullanarak zamanla değişsen bir "gürültü" alıyoruz
        float x = Mathf.PerlinNoise(Time.time * perlinSpeed, 0f);
        float y = Mathf.PerlinNoise(0f, Time.time * perlinSpeed);

        // Değerleri -1 ile 1 arasına çekmek için (x - 0.5) * 2 yapıyoruz
        Vector3 shake = new Vector3((x - 0.5f) * perlinIntensity, (y - 0.5f) * perlinIntensity, 0f);
        m_Camera.transform.localPosition = shake;

        /*
        Ne Oluyor?
        -------------
        Normal Random.Range kullansaydık titreme çok sert olurdu.
        PerlinNoise, bir önceki değerden bir sonraki değere yumuşak geçiş yapar.
        Sonuç: Sarsıntı robotik değil, doğal bir "sallanma" gibi olur.
    */
    }

