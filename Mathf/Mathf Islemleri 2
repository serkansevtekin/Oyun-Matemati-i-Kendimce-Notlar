    [Space]
    [Header("Ekonomi Ayarları")]
    public float baseGold = 50f;    // 1. seviyede alınan temel miktar
    public float multiplier = 100f; // Artışın ne kadar güçlü olacağını belirler
    void CalculateReward(int playerLevel)
    {
        /*
         Formül: Base + (Log10(playerLevel) * Multipler)
         // Log10(1) = 0 -> 1. seviyede sadece baseGold (50) alırsın
         // Log10(10) = 1 -> 10. seviyede  50 + (1 * 100) = 150 altın
         // Log10(100) = 2 -> 100. seviyede 50 + (2 * 100) = 250 altın

        */

        float logValue = Mathf.Log10(playerLevel);
        float totalGold = baseGold + (logValue * multiplier);

        // UI'da göstermek için tam sayıya yufvarlayalım
        int finalReward = Mathf.RoundToInt(totalGold);
        Debug.Log($"logValue: {logValue} | base Altın: {baseGold}");
        Debug.Log($"Level: {playerLevel} | Kazanılan Altın: {finalReward}");
    }
