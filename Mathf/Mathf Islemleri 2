    public float makismumHasar = 100f; // Patlama merkezindeki hasar
    public float patlamaYaricapi = 10f; // Etki alanı
    void PatalamHasariHesapla(Vector3 patalamaMerkezi, Vector3 hedefPozisyon)
    {
        float mesafe = Vector3.Distance(patalamaMerkezi, hedefPozisyon);


        // Eğer patlama alanı içindesye hasar yer
        if (mesafe < patlamaYaricapi)
        {
            // 1/d^2 formülünü uygulayalım
            // Hasar = MaxHasar * (1 / (1 + mesafe^2))
            // '1 + mesafe' kullanmamızın sebebi, 0 olduğunda 1/0 hatasını engellemek

            float hasar = makismumHasar * (1f / (1f + Mathf.Pow(mesafe, 2)));

            Debug.Log("Verilen hasar");
        }

    }

