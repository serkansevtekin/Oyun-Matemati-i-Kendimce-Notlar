    // Akıllı füze veya Takip Eden Ok
    public Transform _target;
    public float speed;
    public float turnSpeed = 2f; // Slerp hızı (kavis kesinliği)
    void HomingProjectile()
    {
        if (_target == null) return;

        // 1. Hedef yönü bul
        Vector3 targetDiff = _target.position - transform.position;

        if (targetDiff.sqrMagnitude < 0.001f) return;

        Vector3 targetDirection = targetDiff.normalized;




        ///  Mesafeye göre hızı arttır (Opsiyonel)
        float distance = Vector3.Distance(transform.position, _target.position);
        float currentSpeed = speed + (10f / (distance + 1f)); // yaklaştıkça hızlanır
        // Kritik Dokunui: Yaklaştıkça dönüş hızını da (turnSpeed) arttırıyoruz!
        float dynamicTurnSpeed = turnSpeed * (5f / (distance + 0.5f));

        if (distance < 0.5) return;
      
        // 2. Kendi yönümüzü yavaşça hedef yön 'Slerp' ile bük
        transform.forward = Vector3.Slerp(transform.forward, targetDirection, Time.deltaTime * dynamicTurnSpeed);


        // 3. İleri git
        transform.position += transform.forward * currentSpeed * Time.deltaTime;
    }

