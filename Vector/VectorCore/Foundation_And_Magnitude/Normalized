/*
    .normalized
    ------------------
        Amaç: Bir vektörün yönünü elede etmek (uzunluğunu 1 yapmak)

        normalized ne yapar?
                        - Vektörün yönünü korur
                        - Uzunluğunu 1'e sabitler
                        - Büyüklük bilgisini atar


        Formül: direction = vector / vector.magnitude


        Ne zaman kullanılır?
                        - Harefekt yönü belirlerken
                        - Sabit hızla ilerlerken
                        - Kuvvet uygularken
                        - Yön kontrolü yaparken



        !!Kritik Nokta!! -> Zero vector (0,0,0) normalize edilmez


*/
public class Normalized_Vector : MonoBehaviour
{

    // Örnek Vektörler
    public Vector3 pointA = new Vector3(1, 0, 1);
    public Vector3 pointB = new Vector3(4, 0, 5);

    public float speed = 5f;

    void Start()
    {

        // 1. fark vektörü
        Vector3 diff = pointB - pointA;
        Debug.Log("Fark vektörü: " + diff);



        // 2. Normalize edilmiş yön
        Vector3 direction = diff.normalized;
        Debug.Log("Normalize edilmiş yön: " + direction);




        // 3. Magnitude kontrolü (1 olmalı)
        Debug.Log("Direciton magnitude: " + direction.magnitude);



        // 4 sabit hızla hareket örneği
        Vector3 velocity = direction * speed;
        Debug.Log("Hız vektörü (direction * speed): " + velocity);



        // 5. Manuel normalize işlemi
        if (diff != Vector3.zero)
        {
            Vector3 manuelDirection = diff / diff.magnitude;
            Debug.Log("Manuel normalize sonucu: " + manuelDirection);
        }


        // 6. Güvenli ve doğru normalize (threshold ile)
        Vector3 move = diff;

        if (move.sqrMagnitude > 0.001f)
        {
            move = move.normalized;
            Debug.Log("Threshold ile normalize edilmiş move: " + move);
        }
        else
        {
            Debug.Log("Move vektörü çok çüçük, normalize edilmedi");
        }

        /*
        Bu threshold yaklaşımı genelde:
                                -> Input normalize ederken
                                -> Çok küçük hareketleri yok saymak isterken
                                -> Fizik jitter engellemek isterken
        */

    }


}
